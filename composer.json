{
    "name": "kirki-framework/kirki",
    "type": "library",
    "version": "5.0.0",
    "keywords": [
        "WordPress",
        "Customizer"
    ],
    "description": "Extending the WordPress customizer",
    "homepage": "https://www.themeum.com",
    "license": "MIT",
    "authors": [
        {
            "name": "Kirki Framework",
            "email": "support@themeum.com"
        }
    ],
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "composer/installers": true
        }
    },
    "include-path": [
        ".",
        "core"
    ],
    "autoload": {
        "psr-4": {
            "Kirki\\Compatibility\\": [
                "customizer/packages/compatibility/src"
            ],
            "Kirki\\Data\\": [
                "customizer/packages/data-option/src"
            ],
            "Kirki\\Field\\": [
                "customizer/packages/field/src/Field",
                "customizer/packages/field-background/src",
                "customizer/packages/field-dimensions/src",
                "customizer/packages/field-fontawesome/src",
                "customizer/packages/field-multicolor/src/Field",
                "customizer/packages/field-multicolor/src",
                "customizer/packages/field-typography/src/Field",
                "customizer/packages/field-typography/src",
                "customizer/packages/control/checkbox/src/Field",
                "customizer/packages/control/code/src/Field",
                "customizer/packages/control/color/src/Field",
                "customizer/packages/control/color-palette/src/Field",
                "customizer/packages/control/custom/src/Field",
                "customizer/packages/control/dashicons/src/Field",
                "customizer/packages/control/date/src/Field",
                "customizer/packages/control/dimension/src/Field",
                "customizer/packages/control/editor/src/Field",
                "customizer/packages/control/generic/src/Field",
                "customizer/packages/control/image/src/Field",
                "customizer/packages/control/multicheck/src/Field",
                "customizer/packages/control/palette/src/Field",
                "customizer/packages/control/radio/src/Field",
                "customizer/packages/control/react-colorful/src/Field",
                "customizer/packages/control/react-select/src/Field",
                "customizer/packages/control/repeater/src/Field",
                "customizer/packages/control/select/src/Field",
                "customizer/packages/control/slider/src/Field",
                "customizer/packages/control/sortable/src/Field",
                "customizer/packages/control/upload/src/Field",
                "customizer/packages/headline-divider/src/Field",
                "customizer/packages/input-slider/src/Field",
                "customizer/packages/margin-padding/src/Field",
                "customizer/packages/responsive/src/Field",
                "customizer/packages/tabs/src/Field"
            ],
            "Kirki\\Module\\": [
                "customizer/packages/module/css/src",
                "customizer/packages/module/editor-styles/src",
                "customizer/packages/module/field-dependencies/src",
                "customizer/packages/module/postmessage/src",
                "customizer/packages/module/preset/src",
                "customizer/packages/module/section-icons/src",
                "customizer/packages/module/selective-refresh/src",
                "customizer/packages/module/tooltips/src",
                "customizer/packages/module/webfonts/src" 
            ],
            "Kirki\\Util\\": [
                "customizer/packages/util/src"
            ],
            "Kirki\\Settings\\": [
                "customizer/packages/settings/src"
            ],
            "Kirki\\": [
                "customizer/packages/control/base/src",
                "customizer/packages/control/checkbox/src",
                "customizer/packages/control/code/src",
                "customizer/packages/control/color/src",
                "customizer/packages/control/color-palette/src",
                "customizer/packages/control/cropped-image/src",
                "customizer/packages/control/custom/src",
                "customizer/packages/control/dashicons/src",
                "customizer/packages/control/date/src",
                "customizer/packages/control/dimension/src",
                "customizer/packages/control/editor/src",
                "customizer/packages/control/generic/src",
                "customizer/packages/control/image/src",
                "customizer/packages/control/multicheck/src",
                "customizer/packages/control/palette/src",
                "customizer/packages/control/radio/src",
                "customizer/packages/control/react-colorful/src",
                "customizer/packages/control/react-select/src",
                "customizer/packages/control/repeater/src",
                "customizer/packages/control/select/src",
                "customizer/packages/control/slider/src",
                "customizer/packages/control/sortable/src",
                "customizer/packages/control/upload/src",
                "customizer/packages/field/src",
                "customizer/packages/googlefonts/src",
                "customizer/packages/l10n/src",
                "customizer/packages/module/panels/src",
                "customizer/packages/module/sections/src",
                "customizer/packages/url-getter/src"
            ],

            "Kirki\\Control\\": [
                "customizer/packages/control/base/src/Control",
                "customizer/packages/control/checkbox/src/Control",
                "customizer/packages/control/code/src/Control",
                "customizer/packages/control/color-palette/src/Control",
                "customizer/packages/control/cropped-image/src",
                "customizer/packages/control/custom/src/Control",
                "customizer/packages/control/dashicons/src/Control",
                "customizer/packages/control/date/src/Control",
                "customizer/packages/control/dimension/src/Control",
                "customizer/packages/control/editor/src/Control",
                "customizer/packages/control/generic/src/Control",
                "customizer/packages/control/image/src/Control",
                "customizer/packages/control/multicheck/src/Control",
                "customizer/packages/control/palette/src/Control",
                "customizer/packages/control/radio/src/Control",
                "customizer/packages/control/react-colorful/src/Control",
                "customizer/packages/control/react-select/src/Control",
                "customizer/packages/control/repeater/src/Control",
                "customizer/packages/control/slider/src/Control",
                "customizer/packages/control/sortable/src/Control",
                "customizer/packages/control/upload/src/Control",
                "customizer/packages/headline-divider/src/Control",
                "customizer/packages/input-slider/src/Control",
                "customizer/packages/margin-padding/src/Control",
                "customizer/packages/responsive/src/Control",
                "customizer/packages/tabs/src/Control"
            ],
            "Kirki\\HeadlineDivider\\": "customizer/packages/headline-divider/src",
            "Kirki\\InputSlider\\": "customizer/packages/input-slider/src",
            "Kirki\\MarginPadding\\": "customizer/packages/margin-padding/src",
            "Kirki\\Responsive\\": "customizer/packages/responsive/src",
            "Kirki\\Tabs\\": "customizer/packages/tabs/src"
        }
    },
    "require": {
        "php": ">=7.0"
    },
    "require-dev": {
        "composer/installers": "*",
        "dealerdirect/phpcodesniffer-composer-installer": "*",
        "wp-coding-standards/wpcs": "*",
        "phpcompatibility/phpcompatibility-wp": "*",
        "wptrt/wpthemereview": "dev-develop"
    }
}
